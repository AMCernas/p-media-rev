# ============================================
# .gitignore - Screen Review App
# ============================================

# ---------------
# Node / npm
# ---------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
yarn.lock

# ---------------
# Next.js
# ---------------
.next/
out/
build/
dist/
*.log

# ---------------
# Production
# ---------------
# .env files (keep .env.example)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---------------
# Testing
# ---------------
coverage/

# ---------------
# Misc
# ---------------
.DS_Store
*.pem
*.icloud
Thumbs.db
~$*

# ---------------
# Debug
# ---------------
npm-debug.log*
yarn-debug.log*

# ---------------
# Local env files
# ---------------
.env*.local

# ---------------
# Vercel
# ---------------
.vercel

# ---------------
# TypeScript
# ---------------
*.tsbuildinfo
next-env.d.ts

# ---------------
# IDE
# ---------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ---------------
# Prisma
# ---------------
# Generated files (if any)
prisma/migrations/

# ---------------
# Design assets (legacy reference)
# ---------------
# Track only code.html files, ignore screenshots
design-legacy/**/*.png
design-legacy/**/*.ico
design-legacy/**/*.jpg